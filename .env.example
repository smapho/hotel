# 楽天ウェブサービス (https://webservice.rakuten.co.jp/) で発行したアプリID。
# 未設定の場合は自動的にモックデータで動作します。
RAKUTEN_APP_ID=

# 楽天のアクセスキー(任意)。通常はアプリIDのみで動作しますが、
# 「specify valid applicationId」エラーが出る場合の切り分け用に、設定すると一緒に送信されます。
RAKUTEN_ACCESS_KEY=

# 楽天アフィリエイトID（任意）。設定するとアフィリエイトリンク経由の予約になります。
RAKUTEN_AFFILIATE_ID=

# true にすると RAKUTEN_APP_ID が設定されていても強制的にモックデータを使用します。
USE_MOCK_HOTELS=false

# Supabaseプロジェクトの Settings > API から取得できるURLとService Role Key。
# 楽天トラベルAPIの結果(地域×宿泊日)をキャッシュし、API呼び出し回数を減らすために使用します。
# 未設定でもアプリは動作します(キャッシュ無しで毎回APIを呼びます)。
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
